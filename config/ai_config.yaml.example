# AI 配置示例
# 使用前请将此文件复制为 ai_config.yaml 并填入真实 API Key
# 复制命令: cp config/ai_config.yaml.example config/ai_config.yaml

# 当前使用的 LLM 模型（从下方 providers 中选一个填入 api_key）
llm:
  provider: deepseek              # 当前使用的提供商
  model: deepseek-chat            # 当前使用的模型
  api_key: ""                     # 填入对应 provider 的 API Key
  base_url: "https://api.deepseek.com"
  temperature: 0.3
  max_tokens: 4096

# LLM 提供商配置（按需填入 API Key）
providers:
  deepseek:
    base_url: "https://api.deepseek.com"
    api_key: ""
    models:
      deepseek-chat: "DeepSeek-V3 通用模型，推荐用例生成/断言分析"
      deepseek-reasoner: "DeepSeek-R1 推理模型，适合复杂根因分析"

  qwen:
    base_url: "https://dashscope.aliyuncs.com/compatible-mode/v1"
    api_key: ""
    models:
      qwen-plus: "通义千问 Plus，性价比高"
      qwen-turbo: "通义千问 Turbo，速度快"
      qwen-max: "通义千问 Max，能力最强"
      qwen-coder-plus: "通义千问代码模型，适合用例生成"

  zhipu:
    base_url: "https://open.bigmodel.cn/api/coding/paas/v4"
    api_key: ""
    models:
      glm-5: "智谱 GLM-5 Plus"

  moonshot:
    base_url: "https://api.moonshot.cn/v1"
    api_key: ""
    models:
      moonshot-v1-8k: "Kimi 8K"
      moonshot-v1-32k: "Kimi 32K"
      moonshot-v1-128k: "Kimi 128K 长上下文"

  doubao:
    base_url: "https://ark.cn-beijing.volces.com/api/v3"
    api_key: ""
    models:
      doubao-pro-4k: "豆包 Pro 4K"
      doubao-pro-32k: "豆包 Pro 32K"
      doubao-pro-128k: "豆包 Pro 128K"

  hunyuan:
    base_url: "https://api.hunyuan.cloud.tencent.com/v1"
    api_key: ""
    models:
      hunyuan-lite: "腾讯混元 Lite，有免费额度"
      hunyuan-standard: "腾讯混元标准版"
      hunyuan-pro: "腾讯混元 Pro"

  siliconflow:
    base_url: "https://api.siliconflow.cn/v1"
    api_key: ""
    models:
      Qwen/Qwen2.5-72B-Instruct: "硅基流动 Qwen2.5-72B"
      deepseek-ai/DeepSeek-V3: "硅基流动 DeepSeek-V3"
      THUDM/glm-4-9b-chat: "硅基流动 GLM-4-9B"

  openai:
    base_url: "https://api.openai.com/v1"
    api_key: ""
    models:
      gpt-4o: "GPT-4o"
      gpt-4o-mini: "GPT-4o Mini"
      gpt-4-turbo: "GPT-4 Turbo"

# AI 用例生成配置
case_generation:
  enable_negative: true       # 启用逆向用例生成
  enable_boundary: true       # 启用边界值用例生成
  enable_security: true       # 启用安全测试用例生成
  max_cases_per_api: 10       # 每个接口最大生成用例数

# Self-Healing 自愈配置
self_healing:
  enabled: true               # 启用自愈引擎
  auto_fix: false             # 自动修复（生产环境建议关闭）
  max_retries: 3              # 最大重试次数

# 断言配置
assertion:
  semantic_check: true        # 语义检查
  schema_check: true          # Schema 检查
